# Twilio configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WEBHOOK_BASE_URL=https://your-app.vercel.app

# Brain / LLM provider: "openai" or "mock"
BRAIN_PROVIDER=mock

# OpenAI (required if BRAIN_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database (Postgres connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/bronius

# Call limits
MAX_TURNS=10
MAX_CALL_DURATION_SEC=300
MAX_SILENCE_RETRIES=2
